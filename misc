local FARMER_LOG = "ExchangeHook/farmer_log.txt"
local function _flog(msg)
    local line = "[" .. os.date("%H:%M:%S") .. "] [EH Farmer] " .. tostring(msg)
    print(line)
    pcall(function()
        if not writefile then return end
        if isfolder and not isfolder("ExchangeHook") then pcall(function() makefolder("ExchangeHook") end) end
        local existing = ""
        pcall(function() if isfile and isfile(FARMER_LOG) and readfile then existing = readfile(FARMER_LOG) end end)
        writefile(FARMER_LOG, existing .. line .. "\n")
    end)
end

local function _farmerSendKey(keyCode)
    _flog("SendKey: " .. tostring(keyCode))
    local ok, err = pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendKeyEvent(true,  keyCode, false, game)
        task.wait(0.08)
        VIM:SendKeyEvent(false, keyCode, false, game)
        task.wait(0.05)
    end)
    if not ok then _flog("SendKey ERROR: " .. tostring(err)) end
end

local function _farmerMouseClick(x, y)
    _flog("=== ClickAtPos " .. tostring(math.floor(x)) .. "," .. tostring(math.floor(y)) .. " ===")
    local cam2 = workspace.CurrentCamera
    if cam2 then
        _flog("  Viewport: " .. tostring(cam2.ViewportSize.X) .. "x" .. tostring(cam2.ViewportSize.Y))
    end

    -- ── EXECUTOR NUCLEAR CLICK: call connected handlers directly ──────────────
    -- getconnections() bypasses all Roblox signal filtering and fires the
    -- actual Lua callback the game registered, regardless of Active/gpe/etc.
    local function _nukeClick(btn)
        local fired = false
        -- Method A: getconnections (best — calls the game's own handler directly)
        pcall(function()
            if typeof(getconnections) ~= "function" then return end
            local signals = {btn.MouseButton1Click, btn.Activated, btn.MouseButton1Down, btn.MouseButton1Up}
            for _, sig in ipairs(signals) do
                local conns = getconnections(sig)
                if conns and #conns > 0 then
                    _flog("    getconnections(" .. tostring(sig) .. ") -> " .. #conns .. " handlers")
                    for _, c in ipairs(conns) do
                        pcall(function() c:Fire() end)
                        fired = true
                    end
                end
            end
        end)
        -- Method B: firesignal (executor API, fires the signal at engine level)
        pcall(function()
            if typeof(firesignal) ~= "function" then return end
            firesignal(btn.MouseButton1Click)
            firesignal(btn.Activated)
            fired = true
            _flog("    firesignal fired")
        end)
        -- Method C: classic Fire (works on some executors)
        pcall(function() btn.MouseButton1Click:Fire() end)
        pcall(function() btn.Activated:Fire() end)
        pcall(function() btn.MouseButton1Down:Fire(0,0) end)
        task.wait(0.04)
        pcall(function() btn.MouseButton1Up:Fire(0,0) end)
        return fired
    end

    -- METHOD 1: GetGuiObjectsAtPosition — find the button, then nuke it
    local pg = player:FindFirstChild("PlayerGui")
    local hitBtn = nil
    if pg then
        local ok, objs = pcall(function() return pg:GetGuiObjectsAtPosition(x, y) end)
        if ok and objs and #objs > 0 then
            _flog("  GetGuiObjectsAtPosition -> " .. #objs .. " objs:")
            for i, obj in ipairs(objs) do
                local ok2, txt = pcall(function() return obj.Text end)
                _flog("    [" .. i .. "] " .. obj.ClassName .. ":\"" .. tostring(obj.Name) .. "\" text=" .. tostring(ok2))
                if not hitBtn and (obj:IsA("TextButton") or obj:IsA("ImageButton") or obj:IsA("GuiButton")) then
                    hitBtn = obj
                end
            end
            if hitBtn then
                _flog("  -> Nuking " .. hitBtn.ClassName .. ":\"" .. tostring(hitBtn.Name) .. "\"")
                _nukeClick(hitBtn)
            else
                _flog("  -> No button class at pos — nuking all objects")
                for _, obj in ipairs(objs) do
                    pcall(function() obj.Activated:Fire() end)
                    pcall(function() obj.MouseButton1Click:Fire() end)
                    if typeof(getconnections) == "function" then
                        pcall(function()
                            for _, c in ipairs(getconnections(obj.MouseButton1Click) or {}) do c:Fire() end
                            for _, c in ipairs(getconnections(obj.Activated) or {}) do c:Fire() end
                        end)
                    end
                end
            end
        else
            _flog("  GetGuiObjectsAtPosition returned nothing — scanning PlayerGui")
            for _, desc in ipairs(pg:GetDescendants()) do
                if (desc:IsA("TextButton") or desc:IsA("ImageButton")) and desc.Visible then
                    local ap = desc.AbsolutePosition
                    local as = desc.AbsoluteSize
                    local ok2, txt = pcall(function() return tostring(desc.Text) end)
                    _flog(string.format("    %s:\"%s\" txt=\"%s\" pos=%d,%d sz=%dx%d",
                        desc.ClassName, desc.Name, ok2 and txt or "?",
                        math.floor(ap.X), math.floor(ap.Y), math.floor(as.X), math.floor(as.Y)))
                end
            end
        end
    else
        _flog("  No PlayerGui!")
    end

    -- METHOD 2: VirtualInputManager (works even if GUI scan missed it)
    task.wait(0.05)
    local vimOk, vimErr = pcall(function()
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendMouseMoveEvent(x, y, game)
        task.wait(0.08)
        VIM:SendMouseButtonEvent(x, y, 0, true,  game, 1)
        task.wait(0.08)
        VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end)
    _flog("  VIM click: " .. (vimOk and "ok" or ("FAILED: " .. tostring(vimErr))))
end

-- Shared nuke-click for find-and-click (defined after _farmerMouseClick is above)
local function _nukeClickBtn(btn)
    local name = btn.ClassName .. ":\"" .. tostring(btn.Name) .. "\""
    _flog("  Nuking " .. name)
    -- getconnections: call the game's actual Lua handler
    pcall(function()
        if typeof(getconnections) ~= "function" then return end
        local sigs = {btn.MouseButton1Click, btn.Activated, btn.MouseButton1Down}
        for _, sig in ipairs(sigs) do
            for _, c in ipairs(getconnections(sig) or {}) do pcall(function() c:Fire() end) end
        end
    end)
    pcall(function() if typeof(firesignal)=="function" then firesignal(btn.MouseButton1Click) end end)
    pcall(function() btn.MouseButton1Click:Fire() end)
    pcall(function() btn.Activated:Fire() end)
    pcall(function() btn.MouseButton1Down:Fire(0,0) end)
    task.wait(0.04)
    pcall(function() btn.MouseButton1Up:Fire(0,0) end)
    -- VIM at button center
    pcall(function()
        local cx = math.floor(btn.AbsolutePosition.X + btn.AbsoluteSize.X * 0.5)
        local cy = math.floor(btn.AbsolutePosition.Y + btn.AbsoluteSize.Y * 0.5)
        local VIM = game:GetService("VirtualInputManager")
        VIM:SendMouseMoveEvent(cx, cy, game)
        task.wait(0.06)
        VIM:SendMouseButtonEvent(cx, cy, 0, true,  game, 1)
        task.wait(0.06)
        VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
    end)
end

local function _farmerFindAndClickButton(patterns)
    local pg = player:FindFirstChild("PlayerGui")
    if not pg then _flog("No PlayerGui found"); return false end
    local found = {}
    for _, gui in ipairs(pg:GetDescendants()) do
        local isBtn = gui:IsA("TextButton") or gui:IsA("ImageButton") or gui:IsA("GuiButton")
        if isBtn and gui.Visible then
            local ok, t = pcall(function() return gui.Text end)
            -- IMPORTANT: button text may be "" — fall back to Name for matching
            local searchStr = (ok and t and t ~= "") and t or gui.Name
            table.insert(found, searchStr)
            local tl = searchStr:lower()
            for _, pat in ipairs(patterns) do
                if tl:find(pat, 1, true) then
                    _flog("Found by pattern \"" .. pat .. "\": " .. gui.ClassName .. ":\"" .. gui.Name .. "\" txt=\"" .. tostring(t) .. "\"")
                    _nukeClickBtn(gui)
                    return true
                end
            end
        end
    end
    _flog("No matching button. Candidates: " .. table.concat(found, " | "))
    return false
end

local function _farmerClickWestSpawn()
    if _farmer.spawnX and _farmer.spawnY then
        _flog("Clicking recorded spawn pos: " .. _farmer.spawnX .. ", " .. _farmer.spawnY)
        _farmerMouseClick(_farmer.spawnX, _farmer.spawnY)
        task.wait(0.2)
        _farmerMouseClick(_farmer.spawnX, _farmer.spawnY)
        return true
    end
    _flog("No recorded pos - searching GUI for west spawn button")
    local found = _farmerFindAndClickButton({"west", "estonian", "spawn on"})
    if not found then
        _flog("GUI search failed - pressing Enter as fallback")
        _farmerSendKey(Enum.KeyCode.Return)
    end
    return true
end

local function _farmerGiveUp()
    _flog("GiveUp: Escape -> R -> Enter")
    _farmerSendKey(Enum.KeyCode.Escape)
    task.wait(0.4)
    _farmerSendKey(Enum.KeyCode.R)
    task.wait(0.4)
    _farmerSendKey(Enum.KeyCode.Return)
    task.wait(0.3)
    _flog("GiveUp: searching GUI for give up button")
    _farmerFindAndClickButton({"give up", "flee", "extract", "leave"})
    return true
end

local function _farmerWalkForward(secs)
    _flog("Walking forward for " .. secs .. "s")
    local t0 = os.clock()
    while os.clock() - t0 < secs and _farmer.running do
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hrp and hum and hum.Health > 0 then
            local fwd = hrp.CFrame.LookVector
            hum:MoveTo(hrp.Position + fwd * 500)
        end
        task.wait(0.1)
    end
    _flog("Walk complete")
end

local function _farmerLoop()
    _flog("Loop started. SpawnPos=" .. tostring(_farmer.spawnX) .. "," .. tostring(_farmer.spawnY))
    local cycle = 0
    while _farmer.running do
        cycle += 1
        _flog("=== Cycle " .. cycle .. " | spawnX=" .. tostring(_farmer.spawnX) .. " spawnY=" .. tostring(_farmer.spawnY) .. " ===")

        _farmerWalkForward(_farmer.walkSecs)
        if not _farmer.running then break end

        _flog("Triggering give up...")
        _farmerGiveUp()

        _flog("Waiting 8s for respawn screen to appear...")
        for i = 1, 8 do
            task.wait(1)
            _flog("  ... " .. i .. "/8s elapsed")
            if not _farmer.running then break end
        end
        if not _farmer.running then break end

        if _farmer.spawnX and _farmer.spawnY then
            _flog("--- PRE-CLICK SCAN ---")
            -- Dump every visible TextButton so we can see what's on screen
            local pg2 = player:FindFirstChild("PlayerGui")
            if pg2 then
                local found2 = {}
                for _, desc in ipairs(pg2:GetDescendants()) do
                    if (desc:IsA("TextButton") or desc:IsA("ImageButton")) and desc.Visible then
                        local ok2, txt2 = pcall(function() return tostring(desc.Text) end)
                        local ap2 = desc.AbsolutePosition
                        local as2 = desc.AbsoluteSize
                        local vis2 = desc:IsDescendantOf(game)
                        table.insert(found2, string.format("  %s:\"%s\" txt=\"%s\" pos=%d,%d sz=%dx%d",
                            desc.ClassName, desc.Name, ok2 and txt2 or "?",
                            math.floor(ap2.X), math.floor(ap2.Y),
                            math.floor(as2.X), math.floor(as2.Y)))
                    end
                end
                if #found2 > 0 then
                    _flog("Visible buttons (" .. #found2 .. "):")
                    for _, s in ipairs(found2) do _flog(s) end
                else
                    _flog("NO visible buttons found in PlayerGui — spawn screen may not be up yet")
                end
            end
            _flog("Clicking recorded pos " .. math.floor(_farmer.spawnX) .. "," .. math.floor(_farmer.spawnY))
            _farmerMouseClick(_farmer.spawnX, _farmer.spawnY)
            task.wait(0.5)
            _flog("Clicking again (double-click for reliability)")
            _farmerMouseClick(_farmer.spawnX, _farmer.spawnY)
        else
            _flog("No spawn pos recorded — falling back to button text search")
            _farmerFindAndClickButton({"west", "estonian", "spawn on"})
        end

        _flog("Waiting 5s for spawn to complete...")
        task.wait(5)
    end
    _flog("Loop ended")
end

