local PlrInfoSection = MiscTab:Section("my reports", "Left")

do
    local _rptLabel = PlrInfoSection:Label("reports: loading...")
    local _flagsLabel = PlrInfoSection:Label("flags: loading...")
    local _hsrLabel = PlrInfoSection:Label("hsr: loading...")
    local _kdLabel = PlrInfoSection:Label("kd: loading...")
    local _ageLabel = PlrInfoSection:Label("account age: loading...")

    local function _updateMyStats()
        pcall(function()
            local statsFolder = ReplicatedStorage:FindFirstChild("Players")
            local myStats = statsFolder and statsFolder:FindFirstChild(player.Name)
            if not myStats then
                _rptLabel:Set("reports: no data"); return
            end

            -- reports
            local uac = myStats:FindFirstChild("Status") and myStats.Status:FindFirstChild("UAC")
            local rptFolder = uac and uac:FindFirstChild("Reports")
            local rptCount = 0
            if rptFolder then
                for _ in pairs(rptFolder:GetAttributes()) do rptCount += 1 end
            end
            _rptLabel:Set("reports: " .. rptCount)

            -- flags / HSR from ReportList
            local rl = ReplicatedStorage:FindFirstChild("ReportList")
            local en = rl and (
                (rl:FindFirstChild("MostWanted") and rl.MostWanted:FindFirstChild(player.Name)) or
                (rl:FindFirstChild("Recent") and rl.Recent:FindFirstChild(player.Name))
            )
            local flags = en and (en:GetAttribute("TotalFlags") or 0) or 0
            local hsr   = en and (en:GetAttribute("HSR") or 0) or 0
            _flagsLabel:Set("flags: " .. flags)
            _hsrLabel:Set("hsr: " .. hsr .. "%")

            -- kills / deaths
            local ws = myStats:FindFirstChild("Status") and myStats.Status:FindFirstChild("Journey")
                       and myStats.Status.Journey:FindFirstChild("WipeStatistics")
            if ws then
                local k = ws:GetAttribute("Kills") or 0
                local d = math.max(ws:GetAttribute("Deaths") or 1, 1)
                _kdLabel:Set("k/d: " .. k .. " / " .. d .. " (" .. string.format("%.2f", k/d) .. ")")
            end

            -- account age
            _ageLabel:Set("account age: " .. player.AccountAge .. "d")
        end)
    end

    PlrInfoSection:Button({Title = "refresh stats", Callback = function()
        task.spawn(_updateMyStats)
    end})

    task.spawn(function() task.wait(3); _updateMyStats() end)
end


