local _recLabel = FarmerSection:Label(_farmer.spawnX and ("spawn @ "..tostring(_farmer.spawnX)..","..tostring(_farmer.spawnY)) or "spawn pos: not set")
FarmerSection:Button({Title = "record spawn click", Callback = function()
    if _farmer.recording then return end
    _farmer.recording = true
    _recLabel:Set("click west spawn now...")
    _flog("Recording mode ON — waiting for next LMB click")
    -- Small delay so this button's own click doesn't get captured
    task.wait(0.4)
    local conn
    conn = game:GetService("UserInputService").InputBegan:Connect(function(inp, gpe)
        -- DO NOT skip on gpe=true: the spawn button IS a GUI element so gpe=true is normal
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            conn:Disconnect()
            local mx = inp.Position.X
            local my = inp.Position.Y
            _farmer.spawnX = mx
            _farmer.spawnY = my
            _farmer.recording = false
            local label = "spawn @ "..tostring(math.floor(mx))..", "..tostring(math.floor(my))
            _recLabel:Set(label)
            _flog("Recorded spawn pos: " .. math.floor(mx) .. ", " .. math.floor(my))
            -- Verify what GUI object is at that position
            local pg = player:FindFirstChild("PlayerGui")
            if pg then
                local ok, objs = pcall(function() return pg:GetGuiObjectsAtPosition(mx, my) end)
                if ok and objs then
                    local names = {}
                    for _, o in ipairs(objs) do table.insert(names, o.ClassName..":"..o.Name) end
                    _flog("Objects at recorded pos: " .. table.concat(names, ", "))
                end
            end
        end
    end)
end})
